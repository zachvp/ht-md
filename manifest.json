{
  "manifest_version": 3,
  "name": "web-md",
  "version": "0.1.0",
  "description": "Pick any element, copy it as Markdown",
  "permissions": ["activeTab", "tabs", "storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "web-md@local"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["turndown.js", "content.js"],
    "css": ["content.css"],
    "run_at": "document_idle"
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
