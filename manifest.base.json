{
  "manifest_version": 3,
  "name": "ht-md",
  "version": "2026.6.23.0",
  "description": "Pick any combination of webpage elements, copy it as Markdown",
  "permissions": ["activeTab", "storage", "scripting"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
