{
  "manifest_version": 3,
  "name": "htmd",
  "version": "6.19.26.6",
  "description": "Pick any combination of elements, copy it as Markdown",
  "permissions": ["activeTab", "tabs", "storage", "scripting"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["turndown.js", "content.js"],
    "css": ["content.css"],
    "run_at": "document_idle"
  }],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
